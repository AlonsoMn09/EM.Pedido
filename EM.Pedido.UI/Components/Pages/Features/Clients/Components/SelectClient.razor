
<GroupBox Titulo="Buscar Clientes">
    <Content>
        <div class="row">
            <div class="col-lg-8 col-md-8 col-sm-12">
                <label>Filtro</label>
                <input class="form-control form-control-sm" @bind="Request.Filter"/>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-12 mt-3"">
                <div class="btn btn-group btn-group-sm">
                    <button class="btn btn-outline-info" @onclick="ListClients"><i class="bi bi-search" /></button>
                    <button class="btn btn-outline-info" @onclick="Refresh"><i class="bi bi-arrow-repeat" /></button>                    
                </div>
            </div>
        </div>
    </Content>
</GroupBox>

<GroupBox Class="mt-4">
    <Content>
        <div class="row mt-3">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm">
                    <thead>
                        <tr class="text-center">                            
                            <th>Razón Social</th>
                            <th>Nro. Documento</th>
                            <th>Contacto</th>
                            <th>Email</th>
                            <th>Celular</th>
                            <th>Rubro</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Response)
                        {
                            <tr class="text-center">                         
                                <td>@item.RazonSocial</td>
                                <td>@item.TipoDocumento - @item.NumeroDocumento</td>
                                <td>@item.Representante</td>
                                <td>@item.Email</td>
                                <td>@item.Celular</td>
                                <td>@item.Rubro</td>
                                <td>
                                    <button class="btn btn-success btn-sm" @onclick="() => OnSelect(item)"><i class="bi bi-check"></i></button>                                    
                                </td>
                            </tr>
                        }                        
                    </tbody>
                </table> 
            </div>
        </div>
        <Pager Result="Pager" OnPageChanged="OnPager" />
    </Content>
</GroupBox>

<Loading IsLoading="IsLoading" />

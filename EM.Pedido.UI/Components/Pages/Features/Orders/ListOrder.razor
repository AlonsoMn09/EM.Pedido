@attribute [Route(ComponentRoutes.Orders.List)]

<GroupBox Class="mb-4">
    <Content>
        <div class="page-header">
            <h2 class="page-title">Mantenimiento de pedidos</h2>
            <span class="page-route">@ComponentRoutes.Orders.List</span>
        </div>
    </Content>
</GroupBox>

<GroupBox Title="Buscar Pedidos">
    <Content>
        <div class="row">
            <div class="col-lg-8 col-md-8 col-sm-12">
                <label>Filtro</label>
                <input class="form-control form-control-sm" @bind="Request.Filter" />
            </div>
            <div class="col-lg-4 col-md-4 col-sm-12 mt-3">
                <div class="btn btn-group btn-group-sm">
                    <button class="btn btn-outline-info" @onclick="ListPedidos"><i class="bi bi-search" /></button>
                    <button class="btn btn-outline-info" @onclick="Refresh"><i class="bi bi-arrow-repeat" /></button>
                    <a class="btn btn-outline-primary" href="@ComponentRoutes.Orders.Create"><i class="bi bi-plus" /> Nuevo</a>
                    <button class="btn btn-outline-success" @onclick="ExportExcel"><i class="bi bi-file-excel" /> Exportar</button>
                </div>
            </div>
        </div>
    </Content>
</GroupBox>

<GroupBox Class="mt-4">
    <Content>
        <div class="row mt-3">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm">
                    <thead class="table-light">
                        <tr class="text-center">
                            <th>Razón social</th>
                            <th>Nro. Documento</th>
                            <th>Total bruto</th>
                            <th>Total neto</th>
                            <th>Adelanto</th>
                            <th>Total</th>
                            <th>Total items</th>
                            <th>Fecha Registro</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Response)
                        {
                            <tr class="text-center">
                                <td>@item.RazonSocial</td>
                                <td>@item.NumeroDocumento</td>
                                <td>@item.TotalBruto</td>
                                <td>@item.TotalNeto</td>
                                <td>@item.Adelanto</td>
                                <td>@item.Total</td>
                                <td>@item.CantidadProductos</td>
                                <td>@item.FechaRegistro</td>
                                <td>
                                    <button class="btn btn-warning btn-sm"><i class="bi bi-eye"></i></button>
                                   
                                </td>
                            </tr>
                        }
                        
                    </tbody>
                </table>
            </div>
        </div>
        <Pager Result="Pager" OnPageChanged="OnPager" OnPageSizeChanged="OnPager" />
    </Content>
</GroupBox>

<Loading IsLoading="IsLoading" />
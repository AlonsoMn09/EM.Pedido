@attribute [Route(ComponentRoutes.Products.List)]
@* @page "/maintenance/clients" *@
@* @using EM.Pedido.UI.Components.Shared *@

<GroupBox Class="mb-4" >
    <Content>
        <div class="page-header">
            <h2 class="page-title">Mantenimiento de Productos</h2>
            <span class="page-route">@ComponentRoutes.Products.List</span>
        </div>
    </Content>
</GroupBox>

<GroupBox Titulo="Buscar Productos">
    <Content>
        <div class="row">
            <div class="col-lg-8 col-md-8 col-sm-12">
                <label>Filtro</label>
                <input class="form-control form-control-sm" @bind="Request.Filter"/>
            </div>
            <div class="col-lg-4 col-md-4 col-sm-12 mt-3"">
                <div class="btn btn-group btn-group-sm">
                    <button class="btn btn-outline-info" @onclick="ListProducts"><i class="bi bi-search" /></button>
                    <button class="btn btn-outline-info" @onclick="Refresh"><i class="bi bi-arrow-repeat" /></button>
                    @* <button class="btn btn-outline-primary"><i class="bi bi-plus"/>Nuevo</button> *@
                    <a class="btn btn-outline-primary" href="@ComponentRoutes.Products.Create"><i class="bi bi-plus" />Nuevo</a>
                    <button class="btn btn-outline-success"><i class="bi bi-file-excel" />Exportar</button>
                </div>
            </div>
        </div>
    </Content>
</GroupBox>

<GroupBox Class="mt-4">
    <Content>
        <div class="row mt-3">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-sm">
                    <thead>
                        <tr class="text-center">                            
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Marca</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Response)
                        {
                            <tr class="text-center">                         
                                <td>@item.Nombre</td>
                                <td>@item.Descripcion</td>
                                <td>@item.Marca</td>
                                <td>@item.Categoria</td>
                                <td>@item.PrecioUnitario</td>
                                <td>@item.Stock</td>
                                <td>
                                    <button class="btn btn-warning btn-sm" @onclick="() => ToEdit(item.Id)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => Delete(item)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }                        
                    </tbody>
                </table> 
            </div>
        </div>
        <Pager Result="Pager" OnPageChanged="OnPager" />
    </Content>
</GroupBox>

<Loading IsLoading="IsLoading" />
